# Copier sur le VPS : cp .env.production.example .env
# Puis éditer avec vos vraies valeurs

# --- URL publique (sans slash final) — pour CORS et liens
# Exemple : http://109.123.254.120 ou https://crm.votredomaine.com
PUBLIC_APP_URL=http://VOTRE_IP_OU_DOMAINE

# --- PostgreSQL (interne Docker, pas exposé) ---
POSTGRES_USER=texta
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort
POSTGRES_DB=texta_crm

DATABASE_URL=postgresql+asyncpg://texta:CHANGEZ_MOI@postgres:5432/texta_crm
DATABASE_URL_SYNC=postgresql://texta:CHANGEZ_MOI@postgres:5432/texta_crm

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (générer : openssl rand -hex 32) ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS = même URL que le site (http://IP si pas de HTTPS) ---
CORS_ORIGINS=http://VOTRE_IP_OU_DOMAINE

API_URL=http://VOTRE_IP_OU_DOMAINE
WEB_URL=http://VOTRE_IP_OU_DOMAINE

# --- Compte admin initial (seed, une seule fois) ---
ADMIN_EMAIL=admin@votredomaine.com
ADMIN_PASSWORD=CHANGEZ_MOI_Admin_Secure!
